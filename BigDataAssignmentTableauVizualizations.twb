    <worksheet name='Cluster economics (bubble)'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#bbbebf' fontname='-apple-system,BlinkMacSystemFont,Segoe WPC,Segoe UI,system-ui,Ubuntu,Droid Sans,sans-serif'>Cluster economics</run>
          </formatted-text>
        </title>
