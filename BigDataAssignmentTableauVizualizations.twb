      <aliases enabled='yes' />
      <column caption='Success Rate' datatype='real' name='[Calculation_1318602962206720]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([label])' />
      </column>
      <column caption='# Campaigns' datatype='integer' name='[Calculation_1318602962354177]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([ID])' />
      </column>
      <column caption='Total Pledged ($)' datatype='real' name='[Calculation_1318602962550786]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([usd_pledged_real])' />
      </column>
      <column caption='Avg Backers' datatype='real' name='[Calculation_1318602962915332]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([backers])' />
      </column>
      <column caption='Overfunded Rate' datatype='real' name='[Calculation_1318602962984965]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([is_overfunded])' />
      </column>
      <column caption='Pledge per Backer' datatype='real' name='[Calculation_1318602963038214]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[usd_pledged_real] / [backers]' />
      </column>
      <column caption='Duration Bucket' datatype='string' name='[Calculation_1318602965504007]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [campaign_duration_days]&lt;=15 THEN &quot;≤15d&quot; ELSEIF [campaign_duration_days]&lt;=30 THEN &quot;16–30d&quot; ELSEIF [campaign_duration_days]&lt;=45 THEN &quot;31–45d&quot; ELSEIF [campaign_duration_days]&lt;=60 THEN &quot;46–60d&quot; ELSE &quot;60d+&quot; END' />
      </column>
      <column caption='Log Goal' datatype='real' name='[Calculation_1318602965573640]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOG([goal])' />
      </column>
      <column caption='Log Backers' datatype='real' name='[Calculation_1318602965622793]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOG([backers])' />
      </column>
      <column caption='Cluster Persona' datatype='string' name='[Calculation_1318602965692426]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [cluster] WHEN 0 THEN &quot;0 · Mainstream small&quot; WHEN 1 THEN &quot;1 · Viral winners&quot; WHEN 2 THEN &quot;2 · Mega blockbusters&quot; WHEN 3 THEN &quot;3 · Ambitious long-shots&quot; END' />
      </column>
      <column caption='Cat Count' datatype='integer' name='[Calculation_1318603148005397]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [category] : COUNT([ID])}' />
      </column>
      <column datatype='integer' name='[ID]' role='dimension' type='ordinal' />
      <column aggregation='None' caption='Log Backers (bin)' datatype='integer' name='[Log Backers (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='-1' formula='[Calculation_1318602965622793]' peg='0' size='0.3' />
