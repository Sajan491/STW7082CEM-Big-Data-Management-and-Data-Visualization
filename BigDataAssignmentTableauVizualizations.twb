            <column caption='Cluster Persona' datatype='string' name='[Calculation_1318603142402065]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [cluster]&#13;&#10;  WHEN 0 THEN &quot;0 · Mainstream small&quot;&#13;&#10;  WHEN 1 THEN &quot;1 · Viral winners&quot;&#13;&#10;  WHEN 2 THEN &quot;2 · Mega blockbusters&quot;&#13;&#10;  WHEN 3 THEN &quot;3 · Ambitious long-shots&quot;&#13;&#10;END' />
