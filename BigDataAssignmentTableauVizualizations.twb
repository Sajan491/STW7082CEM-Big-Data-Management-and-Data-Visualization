            <column caption='Cluster' datatype='integer' name='[cluster]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1318603142402065]' derivation='None' name='[none:Calculation_1318603142402065:nk]' pivot='key' type='nominal' />
            <column caption='Size' datatype='integer' name='[size]' role='measure' type='quantitative' />
            <column caption='Success Rate' datatype='real' name='[success_rate]' role='measure' type='quantitative' />
            <column-instance column='[avg_goal]' derivation='Sum' name='[sum:avg_goal:qk]' pivot='key' type='quantitative' />
            <column-instance column='[avg_pledged]' derivation='Sum' name='[sum:avg_pledged:qk]' pivot='key' type='quantitative' />
